# Container Updater Configuration

# Check interval in minutes (default: 1)
INTERVAL=5

# Only monitor containers with specific label (default: false)
LABELED=false

# Label name to check for when LABELED=true (default: container-updater-enabled)
LABEL=container-updater-enabled

# Custom socket path (optional, auto-detected)
# SOCKET_PATH=/var/run/docker.sock
# For Podman: SOCKET_PATH=/run/podman/podman.sock

# Log level: error, warn, info, debug (default: info)
LOG_LEVEL=info

# Registry credentials for private registries (JSON format)
# Single registry:
# REGISTRY_CREDENTIALS={"registry":"ghcr.io","username":"myuser","password":"mytoken"}
# Multiple registries:
# REGISTRY_CREDENTIALS=[{"registry":"ghcr.io","username":"user1","password":"token1"},{"registry":"registry.example.com","username":"user2","password":"token2"}]

# Custom commands to execute on update detection (JSON array)
# Available environment variables in commands:
#   - CONTAINER_ID, CONTAINER_NAME
#   - CURRENT_IMAGE, CURRENT_TAG
#   - AVAILABLE_IMAGE, AVAILABLE_TAG
#   - UPDATE_TYPE
#
# UPDATE_COMMANDS (deprecated): Use PRE_UPDATE_COMMANDS and POST_UPDATE_COMMANDS instead
# UPDATE_COMMANDS=["echo 'Update found for $CONTAINER_NAME: $CURRENT_TAG -> $AVAILABLE_TAG'"]
#
# PRE_UPDATE_COMMANDS: Execute BEFORE pulling and recreating container
# Examples:
# PRE_UPDATE_COMMANDS=["echo 'Starting update for $CONTAINER_NAME'"]
# PRE_UPDATE_COMMANDS=["curl -X POST https://webhook.site/your-id -d 'Starting update for $CONTAINER_NAME'"]
#
# POST_UPDATE_COMMANDS: Execute AFTER successful container update
# Examples:
# POST_UPDATE_COMMANDS=["echo 'Successfully updated $CONTAINER_NAME to $AVAILABLE_TAG'"]
# POST_UPDATE_COMMANDS=["curl -X POST https://webhook.site/your-id -d 'Updated $CONTAINER_NAME: $CURRENT_TAG -> $AVAILABLE_TAG'"]
# POST_UPDATE_COMMANDS=["docker exec $CONTAINER_NAME /app/healthcheck.sh"]

# GitOps Configuration - Monitor a Git repository for configuration changes
# GITOPS_ENABLED=true
# GITOPS_REPO_URL=https://github.com/user/config-repo.git
# GITOPS_BRANCH=main

# Authentication type: token, ssh, or none
# GITOPS_AUTH_TYPE=token

# For token authentication (GitHub, GitLab, etc.)
# GITOPS_TOKEN=ghp_your_token_here

# For SSH authentication
# GITOPS_SSH_KEY_PATH=/config/id_rsa

# Poll interval for checking git changes (default: 60s)
# GITOPS_POLL_INTERVAL=60s

# Watch specific files/folders (glob patterns) - JSON array
# If not specified, all changes will trigger commands
# GITOPS_WATCH_PATHS=["docker-compose.yml", "config/**/*.env", ".env*"]

# Commands to execute when changes are detected - JSON array
# Available environment variables:
#   - CONTAINER_ID, CONTAINER_NAME, CONTAINER_IMAGE
#   - GIT_COMMIT, GIT_PREVIOUS_COMMIT, GIT_COMMIT_MESSAGE
#   - GIT_CHANGED_FILES (comma-separated list)
# Examples:
# GITOPS_COMMANDS=["docker-compose pull", "docker-compose up -d"]
# GITOPS_COMMANDS=["echo 'Git changes detected: $GIT_COMMIT_MESSAGE'", "docker exec $CONTAINER_NAME nginx -s reload"]

# Parent directory for per-container repo clones. Workloads pointing at the
# same <namespace, repo, branch> share one working tree (one fetch + pull,
# but each workload runs its own commands). Path layout:
#   K8s:    <GITOPS_CLONE_PATH>/<namespace>-<repo>-<branch>
#   Docker: <GITOPS_CLONE_PATH>/<repo>-<branch>
# Default: /tmp
# GITOPS_CLONE_PATH=/tmp

# Clone with --depth 1 to skip repo history. Latest files are still present
# on disk; commands that read repo files work as before. Useful for large
# repos. Default: false.
# GITOPS_SHALLOW=true

# Image labels to display in update notifications (optional, JSON array)
# Each label value is fetched from the registry for the new image and shown
# alongside version info in the notification.
# Only displayed if the label exists on the image — silently omitted otherwise.
# Common OCI labels: org.opencontainers.image.revision, org.opencontainers.image.version
# IMAGE_LABEL=["org.opencontainers.image.revision","org.opencontainers.image.version"]

# Timeout in seconds for fetching image label values from the registry (default: 30)
# Covers the full label fetch operation (manifest + blob fallback). Increase if your
# registry is slow; decrease to fail fast and not block update checks.
# LABEL_FETCH_TIMEOUT=30

# Update Verification & Rollback
# After an auto-update, verify the new version actually comes up healthy before
# reporting success. If it doesn't, roll back to the previous image and send a
# FAILURE notification (instead of a false "success" + repeated re-update loop).
#
# Verify health after updating (default: true)
# HEALTH_CHECK_ENABLED=true
# Seconds to wait for the new version to become healthy (default: 30)
#   Docker: honours the image HEALTHCHECK if present, else requires the
#           container to stay running (no crash/restart loop).
#   K8s:    waits for the rollout to become fully ready.
# HEALTH_CHECK_TIMEOUT=30
# Seconds between health polls (default: 3)
# HEALTH_CHECK_INTERVAL=3
# Restore the previous image when the health check fails (default: true)
#   Docker rolls back by image ID; K8s re-patches the prior image.
# ROLLBACK_ON_FAILURE=true
# After a failed update, don't re-attempt the SAME target image for this long
# (h/m/s). Stops the update/notification spam loop. A newer target is still
# attempted. Set to 0 to disable. Default: 1h
# UPDATE_FAILURE_COOLDOWN=1h

# Webhook notifications
# WEBHOOK_ENABLED=true
# WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# WEBHOOK_PROVIDER=slack          # slack | discord | teams | generic
# WEBHOOK_NOTIFY_SUCCESS=true     # notify on successful update (default: true)
# WEBHOOK_NOTIFY_FAILURE=true     # notify on failed update (default: true)
# WEBHOOK_NOTIFY_CHECK=false      # notify on every check cycle (default: false)
# WEBHOOK_NOTIFY_GITOPS_SUCCESS=true  # notify when GitOps commands succeed (default: true)
# WEBHOOK_NOTIFY_GITOPS_FAILURE=true  # notify when GitOps commands fail (default: true)
