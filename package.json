{
  "name": "containrdog",
  "version": "1.0.0",
  "description": "ContainrDog - Automated container image update monitor for Docker and Podman",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "docker",
    "podman",
    "container",
    "update",
    "monitor",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "dockerode": "^4.0.2",
    "node-cron": "^3.0.3",
    "semver": "^7.6.3",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.18.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
