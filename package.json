{
  "name": "containrdog",
  "version": "1.0.0",
  "description": "ContainrDog - Automated container image update monitor for Docker and Podman",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "watch": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "INTEGRATION_TESTS=true vitest run tests/integration",
    "test:e2e:docker": "bash tests/e2e/docker/run.sh",
    "test:e2e:k8s": "bash tests/e2e/kubernetes/run.sh"
  },
  "keywords": [
    "docker",
    "podman",
    "container",
    "update",
    "monitor",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-ecr": "^3.709.0",
    "@kubernetes/client-node": "^0.21.0",
    "axios": "^1.7.9",
    "dockerode": "^4.0.2",
    "minimatch": "^10.0.3",
    "node-cron": "^3.0.3",
    "semver": "^7.6.3",
    "simple-git": "^3.28.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.31",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.18.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
